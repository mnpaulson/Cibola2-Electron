{
  "name": "cibola2-electron",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "electron-updater": "^6.8.9",
    "fuse.js": "^7.4.2",
    "vue": "^3.4.27",
    "vuetify": "^3.6.8"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.11",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vite-plugin-vuetify": "^2.0.3"
  },
  "build": {
    "appId": "com.cibola2.electron",
    "productName": "Cibola2",
    "icon": "public/256x256.png",
    "publish": [
      {
        "provider": "github",
        "owner": "mnpaulson",
        "repo": "Cibola2-Electron"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "public/256x256.png",
      "target": [
        "nsis"
      ]
    }
  }
}